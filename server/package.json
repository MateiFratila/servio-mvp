{
  "name": "servio-server",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:deploy": "dotenv -e ../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:studio": "dotenv -e ../.env -- prisma studio --schema=prisma/schema.prisma",
    "db:seed": "dotenv -e ../.env -- prisma db seed --schema=prisma/schema.prisma",
    "db:clear": "dotenv -e ../.env -- node prisma/clear.js",
    "db:clear:prod": "dotenv -e ../.env.prod -- node prisma/clear.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0"
  }
}
