// Prisma schema for Servio
// Docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  client
  consultant
  admin
}

enum SessionStatus {
  pending
  pending_confirmation
  ping_pong
  confirmed
  completed
  cancelled
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String?  @map("phone")
  role         Role     @default(client)
  resetPasswordToken   String?   @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  isEmailConfirmed       Boolean   @default(false) @map("is_email_confirmed")
  emailConfirmationToken String?   @unique @map("email_confirmation_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile            ConsultantProfile?
  sessions           Session[]          @relation("ClientSessions")
  uploadedDocuments  SessionDocument[]  @relation("DocumentUploader")
  sentMessages       SessionMessage[]   @relation("MessageAuthor")
  reviews            Review[]           @relation("ClientReviews")
  reviewReplies      ReviewReply[]      @relation("ReviewReplies")

  @@map("users")
}

model ConsultantProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  displayName    String   @map("display_name")
  slug           String?  @unique @map("slug")
  description    String?  @db.Text
  hourlyRate     Decimal  @map("hourly_rate") @db.Decimal(10, 2)
  avatarUrl                String?  @map("avatar_url")
  avatarBlobName           String?  @map("avatar_blob_name") @db.Text
  bannerUrl                String?  @map("banner_url")
  bannerBlobName           String?  @map("banner_blob_name") @db.Text
  languages                Json?    @map("languages")
  isActive                 Boolean  @default(true) @map("is_active")
  stripeAccountId          String?  @map("stripe_account_id")
  stripeOnboardingComplete Boolean  @default(false) @map("stripe_onboarding_complete")
  publicationRequested     Boolean  @default(false) @map("publication_requested")
  platformFeePct           Decimal  @default(30) @map("platform_fee_pct") @db.Decimal(5, 2)
  averageRating            Decimal  @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilitySlots  AvailabilitySlot[]
  sessions           Session[]                    @relation("ConsultantSessions")
  expertiseCategories ConsultantProfileCategory[]
  specialisations    ConsultantProfileSpecialisation[]
  tags               ConsultantTag[]
  reviews            Review[]                     @relation("ConsultantReviews")

  @@map("consultant_profiles")
}

model Specialisation {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  profiles       ConsultantProfileSpecialisation[]
  expertiseAreas ExpertiseCategory[]
  suggestedAreas SuggestedExpertiseArea[]

  @@map("specialisations")
}

model ConsultantProfileSpecialisation {
  profileId        Int @map("profile_id")
  specialisationId Int @map("specialisation_id")

  profile        ConsultantProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  specialisation Specialisation    @relation(fields: [specialisationId], references: [id], onDelete: Cascade)

  @@id([profileId, specialisationId])
  @@map("consultant_profile_specialisations")
}

model ExpertiseCategory {
  id               Int  @id @default(autoincrement())
  name             String @unique
  slug             String @unique
  specialisationId Int?   @map("specialisation_id")

  specialisation Specialisation?           @relation(fields: [specialisationId], references: [id], onDelete: SetNull)
  profiles       ConsultantProfileCategory[]

  @@index([specialisationId])
  @@map("expertise_categories")
}

model ConsultantProfileCategory {
  profileId  Int @map("profile_id")
  categoryId Int @map("category_id")

  profile  ConsultantProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category ExpertiseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([profileId, categoryId])
  @@map("consultant_profile_categories")
}

model ConsultantTag {
  id           Int    @id @default(autoincrement())
  consultantId Int    @map("consultant_id")
  tag          String

  consultant ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([consultantId, tag])
  @@index([tag])
  @@map("consultant_tags")
}

model AvailabilitySlot {
  id           Int      @id @default(autoincrement())
  consultantId Int      @map("consultant_id")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  isBooked     Boolean  @default(false) @map("is_booked")

  consultant ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  session    Session?

  @@index([consultantId, startTime])
  @@map("availability_slots")
}

model Session {
  id                    Int           @id @default(autoincrement())
  clientId              Int           @map("client_id")
  consultantId          Int           @map("consultant_id")
  slotId                Int           @unique @map("slot_id")
  durationMinutes       Int           @default(30) @map("duration_minutes")
  status                SessionStatus @default(pending)
  notes                 String?       @db.Text
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  paymentStatus         String        @default("unpaid") @map("payment_status")
  meetingUrl            String?       @map("meeting_url")
  dailyRoomName         String?       @map("daily_room_name")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  client     User              @relation("ClientSessions", fields: [clientId], references: [id])
  consultant ConsultantProfile @relation("ConsultantSessions", fields: [consultantId], references: [id])
  slot       AvailabilitySlot  @relation(fields: [slotId], references: [id])
  documents  SessionDocument[]
  messages   SessionMessage[]
  billing    SessionBilling?
  review     Review?

  @@index([clientId])
  @@index([consultantId, status])
  @@map("sessions")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model SessionMessage {
  id                  Int      @id @default(autoincrement())
  sessionId           Int      @map("session_id")
  authorId            Int      @map("author_id")
  content             String?  @db.Text
  attachmentFilename  String?  @map("attachment_filename")
  attachmentBlobName  String?  @map("attachment_blob_name") @db.Text
  attachmentSizeBytes Int?     @map("attachment_size_bytes")
  createdAt           DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author  User    @relation("MessageAuthor", fields: [authorId], references: [id])

  @@index([sessionId])
  @@map("session_messages")
}

model SessionDocument {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  filename    String
  contentType String   @map("content_type")
  blobName    String   @map("blob_name") @db.Text
  sizeBytes   Int      @map("size_bytes")
  uploadedBy  Int      @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  uploader User    @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([sessionId])
  @@map("session_documents")
}

model SessionBilling {
  id             Int      @id @default(autoincrement())
  sessionId      Int      @unique @map("session_id")
  billingType    String   @map("billing_type") // "fizica" | "juridica"
  
  // Persoana Fizica
  name           String?
  cnp            String?
  localitate     String?
  judet          String?

  // Persoana Juridica
  companyName    String?  @map("company_name")
  cui            String?
  regCom         String?  @map("reg_com")
  companyAddress String?  @map("company_address")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_billing")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  type      String   // "contact" or "feedback"
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

model Review {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @unique @map("session_id")
  clientId     Int      @map("client_id")
  consultantId Int      @map("consultant_id")
  rating       Int
  testimonial  String   @db.Text
  displayName  String?  @map("display_name")
  privateNotes String?  @db.Text @map("private_notes")
  createdAt    DateTime @default(now()) @map("created_at")

  session    Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client     User              @relation("ClientReviews", fields: [clientId], references: [id])
  consultant ConsultantProfile @relation("ConsultantReviews", fields: [consultantId], references: [id])
  replies    ReviewReply[]

  @@index([clientId])
  @@index([consultantId])
  @@map("reviews")
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  reviewId  Int      @map("review_id")
  authorId  Int      @map("author_id")
  index     Int      @map("index")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author User   @relation("ReviewReplies", fields: [authorId], references: [id])

  @@index([reviewId])
  @@map("review_replies")
}

model SuggestedSpecialisation {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("suggested_specialisations")
}

model SuggestedExpertiseArea {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  specialisationId Int      @map("specialisation_id")
  status           String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt        DateTime @default(now()) @map("created_at")

  specialisation Specialisation @relation(fields: [specialisationId], references: [id], onDelete: Cascade)

  @@index([specialisationId])
  @@map("suggested_expertise_areas")
}
