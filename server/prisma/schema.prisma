// Prisma schema for Servio
// Docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  client
  consultant
  admin
}

enum SessionStatus {
  pending
  confirmed
  completed
  cancelled
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(client)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile            ConsultantProfile?
  sessions           Session[]          @relation("ClientSessions")
  uploadedDocuments  SessionDocument[]  @relation("DocumentUploader")

  @@map("users")
}

model ConsultantProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  displayName    String   @map("display_name")
  description    String?  @db.Text
  specialisation String
  hourlyRate     Decimal  @map("hourly_rate") @db.Decimal(10, 2)
  avatarUrl      String?  @map("avatar_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilitySlots AvailabilitySlot[]
  sessions          Session[]          @relation("ConsultantSessions")

  @@map("consultant_profiles")
}

model AvailabilitySlot {
  id           Int      @id @default(autoincrement())
  consultantId Int      @map("consultant_id")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  isBooked     Boolean  @default(false) @map("is_booked")

  consultant ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  session    Session?

  @@index([consultantId, startTime])
  @@map("availability_slots")
}

model Session {
  id                    Int           @id @default(autoincrement())
  clientId              Int           @map("client_id")
  consultantId          Int           @map("consultant_id")
  slotId                Int           @unique @map("slot_id")
  status                SessionStatus @default(pending)
  notes                 String?       @db.Text
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  paymentStatus         String        @default("unpaid") @map("payment_status")
  meetingUrl            String?       @map("meeting_url")
  dailyRoomName         String?       @map("daily_room_name")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  client     User              @relation("ClientSessions", fields: [clientId], references: [id])
  consultant ConsultantProfile @relation("ConsultantSessions", fields: [consultantId], references: [id])
  slot       AvailabilitySlot  @relation(fields: [slotId], references: [id])
  documents  SessionDocument[]

  @@index([clientId])
  @@index([consultantId, status])
  @@map("sessions")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model SessionDocument {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  filename    String
  contentType String   @map("content_type")
  blobName    String   @map("blob_name") @db.Text
  sizeBytes   Int      @map("size_bytes")
  uploadedBy  Int      @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  uploader User    @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([sessionId])
  @@map("session_documents")
}
