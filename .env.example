PORT=3000
NODE_ENV=development

JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=1h

# Prisma connection string — format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Add ?sslaccept=strict for Azure MySQL Flexible Server (SSL enforced by default)
DATABASE_URL="mysql://root:changeme@localhost:3306/servio"
# DATABASE_URL="mysql://user:pass@yourserver.mysql.database.azure.com:3306/servio-db?sslaccept=strict"

# Stripe — use test keys (sk_test_ / pk_test_) for development, live keys for production
# Server-side secret key (never expose this to the client)
STRIPE_SECRET_KEY=sk_test_changeme
# Webhook signing secret — get from `stripe listen` output (local) or Stripe Dashboard → Webhooks (production)
STRIPE_WEBHOOK_SECRET=whsec_changeme
# Client-side publishable key (served via /api/config — safe to expose in the browser)
STRIPE_PUBLISHABLE_KEY=pk_test_changeme
