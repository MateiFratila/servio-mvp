PORT=3000
NODE_ENV=development

JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=1h

# Prisma connection string — format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Add ?sslaccept=strict for Azure MySQL Flexible Server (SSL enforced by default)
DATABASE_URL="mysql://root:changeme@localhost:3306/servio"
# DATABASE_URL="mysql://user:pass@yourserver.mysql.database.azure.com:3306/servio-db?sslaccept=strict"
